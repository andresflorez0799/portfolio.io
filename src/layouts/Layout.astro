---
import { basics } from "@cv";

interface Props {
    title: string;
}
const { title } = Astro.props;
const { image, summary, url } = basics;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <title>{title}</title>
        <meta name="description" content={summary} />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preload" as="image" href={image} />
        <meta property="og:url" content={url} />
        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={summary} />
        <meta property="og:image" content="" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta property="twitter:domain" content={url.split("//")[1] ?? ""} />
        <meta property="twitter:url" content={url} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={summary} />
        <meta name="twitter:image" content="" />
    </head>
    <body class="no-scrollbars">
        <slot />
    </body>
</html>

<style is:global>
    :root {
        color-scheme: light;
        --bg: #f7f8fb;
        --bg-soft: #ffffff;
        --surface: rgba(255, 255, 255, 0.78);
        --surface-strong: #ffffff;
        --text: #111827;
        --muted: #5f6878;
        --subtle: #8b95a7;
        --border: rgba(17, 24, 39, 0.1);
        --accent: #0f766e;
        --accent-strong: #14b8a6;
        --accent-soft: rgba(20, 184, 166, 0.14);
        --rose: #e11d48;
        --amber: #f59e0b;
        --shadow: 0 22px 70px rgba(15, 23, 42, 0.11);
        --radius: 8px;
        --mono:
            "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
        --sans:
            Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
            "Segoe UI", sans-serif;
    }

    html {
        scroll-behavior: smooth;
        font-family: var(--sans);
        background:
            linear-gradient(135deg, rgba(20, 184, 166, 0.11), transparent 34%),
            linear-gradient(315deg, rgba(225, 29, 72, 0.08), transparent 30%),
            var(--bg);
        color: var(--text);
        letter-spacing: 0;
    }

    body,
    figure {
        margin: 0;
        padding: 0;
    }

    body {
        min-height: 100vh;
        overflow-x: hidden;
    }

    body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background-image:
            linear-gradient(rgba(17, 24, 39, 0.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(17, 24, 39, 0.04) 1px, transparent 1px);
        background-size: 44px 44px;
        mask-image: linear-gradient(to bottom, black, transparent 78%);
    }

    /* Hide scrollbar for Chrome, Safari and Opera */
    html::-webkit-scrollbar {
        display: none;
    }

    /* Hide scrollbar for IE, Edge and Firefox */
    html {
        -ms-overflow-style: none; /* IE and Edge */
        scrollbar-width: none; /* Firefox */
    }
    a {
        color: inherit;
        text-decoration: none;
    }
    ul {
        list-style: none;
        margin: 0;
        padding: 0;
    }
    *,
    *::before,
    *::after {
        box-sizing: border-box;
    }
    footer span {
        color: var(--text);
        background: var(--accent-soft);
    }

    time {
        color: var(--subtle);
        font-family: var(--mono);
    }
    h1,
    h2,
    h3,
    h4 {
        margin: 0;
        font-family:
            system-ui,
            -apple-system,
            BlinkMacSystemFont,
            "Segoe UI",
            Roboto,
            Oxygen,
            Ubuntu,
            Cantarell,
            "Open Sans",
            "Helvetica Neue",
            sans-serif;
    }

    p {
        color: var(--muted);
        font-size: 0.98rem;
        line-height: 1.72;
        margin: 0;
        text-wrap: pretty;
    }

    ::selection {
        color: #06201d;
        background: rgba(45, 212, 191, 0.42);
    }

    :focus-visible {
        outline: 3px solid rgba(20, 184, 166, 0.45);
        outline-offset: 3px;
    }

    .print {
        display: none !important;
    }

    /*Dark Theme*/
    html.dark {
        color-scheme: dark;
        --bg: #090b10;
        --bg-soft: #111827;
        --surface: rgba(17, 24, 39, 0.72);
        --surface-strong: #111827;
        --text: #f8fafc;
        --muted: #b8c0cc;
        --subtle: #8a94a6;
        --border: rgba(248, 250, 252, 0.12);
        --accent: #2dd4bf;
        --accent-strong: #5eead4;
        --accent-soft: rgba(45, 212, 191, 0.16);
        --shadow: 0 24px 80px rgba(0, 0, 0, 0.34);
        background:
            linear-gradient(135deg, rgba(45, 212, 191, 0.12), transparent 32%),
            linear-gradient(315deg, rgba(244, 63, 94, 0.11), transparent 28%),
            var(--bg);
    }

    .dark body::before {
        background-image:
            linear-gradient(rgba(248, 250, 252, 0.055) 1px, transparent 1px),
            linear-gradient(90deg, rgba(248, 250, 252, 0.055) 1px, transparent 1px);
    }

    /*no scroll*/
    @tailwind base;
    @tailwind components;
    @tailwind utilities;
    @layer utilities {
        /* Hide scrollbar for Chrome, Safari and Opera */
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        /* Hide scrollbar for IE, Edge and Firefox */
        .no-scrollbar {
            -ms-overflow-style: none; /* IE and Edge */
            scrollbar-width: none; /* Firefox */
        }
    }

    /*no print*/
    @media print {
        :root,
        html.dark {
            --bg: #fff;
            --surface: #fff;
            --surface-strong: #fff;
            --text: #111;
            --muted: #444;
            --border: #ddd;
            --shadow: none;
        }

        html,
        body {
            background: #fff !important;
        }

        body::before {
            display: none;
        }

        .no-print {
            display: none !important;
        }

        .print {
            display: block !important;
        }

        astro-dev-toolbar {
            display: none !important;
        }

        article {
            break-inside: avoid;
        }
    }
</style>
