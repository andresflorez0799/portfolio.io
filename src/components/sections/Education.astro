---
import Section from "../Section.astro";

import { education, certificates } from "@cv";
---

<Section id="educacion" title="Educación">
    <ul>
        {
            education.map(({ institution, startDate, endDate, area, url }) => {
                const startYear = new Date(startDate).getFullYear();
                const endYear = endDate != null ? new Date(endDate).getFullYear() : "Actual";
                const years = `${startYear} - ${endYear}`;

                return (
                    <li>
                        <article>
                            <header>
                                <div>
                                    <h3>
                                        <a href={url} title={`Ir ${institution}`} target="_blank">
                                            {institution}
                                        </a>
                                    </h3>
                                </div>
                                <time>{years}</time>
                            </header>

                            <footer>
                                <p>{area}</p>
                            </footer>
                        </article>
                    </li>
                );
            })
        }
    </ul>
</Section>

<Section subtitle="Cursos y Certificaciones">
    <ul>
        {
            certificates.map(({ issuer, courses, url }) => {
                const data = courses.map(({ name, date, url, ID }) => {
                    const dateString = `${date.toLocaleString()}`;

                    return (
                        <article>
                            <header>
                                <p>
                                    <a href={url} target="_blank" title={`Ver certificado en linea de: ${name}`}>
                                        {name}
                                    </a>
                                </p>
                                <time>{dateString}</time>
                            </header>
                            <footer hidden>
                                {ID && (
                                    <p>
                                        Id: <span>{ID}</span>
                                    </p>
                                )}
                            </footer>
                        </article>
                    );
                });

                return (
                    <li>
                        <h3>
                            <a target="_blank" href={url}>{issuer}</a>
                        </h3>
                        {data}
                    </li>
                );
            })
        }
    </ul>
</Section>

<style>
    ul {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    li > h3 {
        color: var(--accent);
        font-weight: 600;
        font-size: 1.2rem;
        margin: 1.2rem auto 0.7rem;
    }

    article h3 {
        font-weight: 800;
    }

    article {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 0.9rem 1rem;
        transition:
            background 180ms ease,
            border-color 180ms ease,
            transform 180ms ease;
    }

    article:hover {
        background: var(--surface-strong);
        border-color: rgba(20, 184, 166, 0.28);
        transform: translateX(4px);
    }

    header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 0.15rem;
    }

    a:hover {
        color: var(--accent);
    }

    time {
        background: var(--accent-soft);
        border-radius: 999px;
        color: var(--accent);
        font-size: 0.85rem;
        font-weight: 800;
        min-width: 102px;
        padding: 0.32rem 0.55rem;
        text-align: center;
    }

    p > a:hover {
        cursor: pointer;
        color: var(--accent);
    }

    footer > p > span {
        font-size: 0.65rem;
        font-weight: 500;
    }

    @media (width <= 700px) {
        header {
            flex-direction: column;
        }

        time {
            text-align: left;
        }
    }

    @media print {
        article {
            border: 0;
            padding: 0;
        }

        time {
            background: transparent;
            color: #444;
            padding: 0;
        }
    }
</style>
