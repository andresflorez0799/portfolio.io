---
import GitHub from "@/icons/GitHub.astro";
import Section from "../Section.astro";

import { projects } from "@cv";
---

<Section id="proyectos" title="Proyectos">
    <ul>
        {
            projects.map(({ url, description, highlights, name, isActive, github }) => {
                return (
                    <li>
                        <article>
                            <header>
                                <h3>
                                    <a href={url} target="_blank" title={`Ver el proyecto ${name}`}>
                                        {name}
                                    </a>
                                    {isActive && <span class="status">Activo</span>}
                                    {github && (
                                        <a class="github-code-link" href={github} target="_blank" title={`Ver código fuente del proyecto ${name}`}>
                                            <GitHub />
                                        </a>
                                    )}
                                </h3>
                                <p>{description}</p>
                            </header>
                            <footer>
                                {highlights.map((highlight) => {
                                    return <span>{highlight}</span>;
                                })}
                            </footer>
                        </article>
                    </li>
                );
            })
        }
    </ul>
</Section>
<style>
    ul {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
        gap: 1rem;
    }

    article {
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent),
            var(--surface);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        box-shadow: 0 18px 52px rgba(15, 23, 42, 0.06);
        gap: 1rem;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        padding: 1rem;
        position: relative;
        height: 100%;
        transition:
            border-color 180ms ease,
            transform 180ms ease,
            box-shadow 180ms ease;
    }

    article::before {
        background: linear-gradient(90deg, var(--accent), var(--rose));
        content: "";
        height: 3px;
        left: 0;
        position: absolute;
        top: 0;
        width: 100%;
    }

    article:hover {
        border-color: rgba(20, 184, 166, 0.32);
        box-shadow: var(--shadow);
        transform: translateY(-4px);
    }

    article header {
        flex: 1;
    }

    article h3 {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-bottom: 0.55rem;
        font-size: 1.1rem;
        line-height: 1.25;
    }

    article a:hover {
        color: var(--accent);
    }

    article p {
        font-size: 0.88rem;
        line-height: 1.55;
        margin-bottom: 0.25rem;
    }

    .status {
        align-items: center;
        background: rgba(34, 197, 94, 0.12);
        border: 1px solid rgba(34, 197, 94, 0.24);
        border-radius: 999px;
        color: #16a34a;
        display: inline-flex;
        font-family: var(--mono);
        font-size: 0.62rem;
        font-weight: 800;
        gap: 0.28rem;
        padding: 0.18rem 0.45rem;
        text-decoration: none;
    }

    .status::before {
        background: currentColor;
        border-radius: 999px;
        content: "";
        height: 0.42rem;
        width: 0.42rem;
    }

    footer {
        display: flex;
        flex-wrap: wrap;
        gap: 0.38rem;
        font-size: 0.6rem;
    }

    footer span {
        background: var(--bg-soft);
        border: 1px solid var(--border);
        border-radius: 999px;
        color: var(--muted);
        font-size: 0.64rem;
        font-weight: 700;
        padding: 0.18rem 0.45rem;
    }

    .github-code-link {
        align-items: center;
        display: inline-flex;
        margin-left: 0;
    }

    @keyframes flicker {
        0% {
            opacity: 1;
        }
        50% {
            opacity: 0.25;
        }
        100% {
            opacity: 1;
        }
    }

    @media (width <= 700px) {
        ul {
            margin-inline: 0px;
        }

        article {
            border: none;
            padding: 0 0 16px 0;
        }
    }

    @media print {
        html,
        body {
            height: 100%;
        }

        article h3 span {
            animation-name: none;
        }

        article {
            border: 1px solid #ddd;
            box-shadow: none;
            break-inside: avoid;
        }
    }
</style>
